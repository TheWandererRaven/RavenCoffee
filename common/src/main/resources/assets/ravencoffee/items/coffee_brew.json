        }
      },
      {
        "when": "ravencoffee:honey",
        "model": {
          "type": "minecraft:model",
          "model": "ravencoffee:item/coffee_brew_honey"
        }
      },
      {
        "when": "ravencoffee:melon",
        "model": {
          "type": "minecraft:model",
          "model": "ravencoffee:item/coffee_brew_melon"
